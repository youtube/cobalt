{
  "docker_service": "build-rdk",
  "on_device_test": {
    "enabled": true,
    "tests": [
      "0",
      "1",
      "2",
      "3",
      "4",
      "5"
    ]
  },
  "platforms": [
    "rdk-arm-sbversion-15",
    "rdk-arm-sbversion-16"
  ],
  "includes": [
    {
      "name":"sbversion-15",
      "platform":"rdk-arm-sbversion-15",
      "target_platform":"rdk-arm",
      "target_cpu":"target_cpu=\\\"arm\\\"",
      "extra_gn_arguments": "is_clang=false using_old_compiler=true rdk_build_without_yocto=true rdk_enable_securityagent=false",
      "sb_api_version": "15",
      "dimension": "release_version=regex:10.*"
    },
    {
      "name":"sbversion-16",
      "platform":"rdk-arm-sbversion-16",
      "target_platform":"rdk-arm",
      "target_cpu":"target_cpu=\\\"arm\\\"",
      "extra_gn_arguments": "is_clang=false using_old_compiler=true rdk_build_without_yocto=true rdk_enable_securityagent=false",
      "sb_api_version": "16",
      "dimension": "release_version=regex:10.*"
    }
  ]
}
