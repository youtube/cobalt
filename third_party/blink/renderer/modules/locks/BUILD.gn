import("//content/public/common/features.gni")
import("//third_party/blink/renderer/modules/modules.gni")

blink_modules_sources("locks") {
  sources = [
    "lock.cc",
    "lock.h",
    "lock_manager.cc",
    "lock_manager.h",
  ]

  deps =
      [ "//third_party/blink/renderer/modules/shared_storage:shared_storage" ]

  if (!enable_privacy_sandbox_apis) {
    deps -= [ "//third_party/blink/renderer/modules/shared_storage:shared_storage" ]
  }
}
