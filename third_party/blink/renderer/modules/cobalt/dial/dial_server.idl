// Imported from C25:
// https://github.com/youtube/cobalt/blob/25.lts.1%2B/cobalt/h5vcc/dial/dial_server.idl

[
 Exposed=Window,
 SecureContext
]
interface DialServer {
  [CallWith=ExecutionContext] constructor(DOMString serviceName);

  readonly attribute DOMString serviceName;

  // Per C25 behavior, these methods return false if a listener for a given
  // path is already registered.
  boolean onDelete(DOMString path, DialHttpRequestCallback listener);
  boolean onGet(DOMString path, DialHttpRequestCallback listener);
  boolean onPost(DOMString path, DialHttpRequestCallback listener);
};

callback DialHttpRequestCallback = boolean (DialHttpRequest request, DialHttpResponse response);
